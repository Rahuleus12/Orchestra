# Normalize line endings to LF in the working tree on all platforms.
# Go tooling (gofmt, gofmt) requires LF endings.

# Default: treat as text, normalize to LF
* text=auto eol=lf

# Go source — always LF
*.go    text eol=lf
*.s     text eol=lf
*.S     text eol=lf

# Configuration / text assets — LF
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.tmpl  text eol=lf
*.txt   text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
Makefile text eol=lf
*.sh    text eol=lf
Dockerfile text eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.gz    binary
